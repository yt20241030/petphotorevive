# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.
# Never commit the real values — .env* is gitignored.

# BLOB_READ_WRITE_TOKEN — do NOT set this by hand. It's auto-injected by
# Vercel once a Blob store is connected to the project (Storage tab →
# Create Database → Blob → Connect Project). Without it, jobs fall back to
# in-process memory, which only works for a single local `next dev` run.

# Replicate — leave unset to use the free sharp-basic placeholder engine.
# Set it and the site automatically switches to the real restoration
# pipeline (flux-restore primary: Flux Restore + Real-ESRGAN upscale).
REPLICATE_API_TOKEN=

# Optional: set to "realesrgan" to force the backup enhance-only engine
# (Real-ESRGAN x4+sharpen, no generative re-rendering). Leave unset for
# the flux-restore primary.
RESTORE_ENGINE=

# Dodo Payments — test mode key first. Leave unset and checkout runs in
# demo mode (marks the job paid locally, no real charge, for pipeline testing).
DODO_API_KEY=
DODO_WEBHOOK_SECRET=

# Brand name / parent brand / price are NOT env vars — they're plain
# constants in src/lib/brand.ts (change that file, redeploy). Kept out of
# env because PRICE_USD is also read client-side and non-NEXT_PUBLIC_ env
# vars aren't available in the browser bundle.

# Free watermarked previews allowed per IP per day (anti-abuse backstop
# behind the per-user FREE_TRIES quota). Counts every generation incl. free
# retries, so keep it above one user's realistic max (~3 photos x 3 = 9).
FREE_PREVIEWS_PER_DAY=15

# Total free portrait tries per anonymous user (the primary free quota).
FREE_TRIES=3

# Free retries per portrait — "Not quite right? Retry for free." After a photo
# is paid for once (a free try or a credit), the next N generations of that SAME
# photo (same style or different) cost nothing. Keyed by anonId+image hash to
# block abuse. Founder's call: 2.
FREE_RETRIES_PER_PORTRAIT=2

# Site-wide daily cap on restoration engine calls (spend guard for
# Replicate). Resets at UTC midnight. Raise it here / in Vercel env vars —
# no code change needed.
DAILY_RESTORE_LIMIT=500
