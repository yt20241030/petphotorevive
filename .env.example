# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.
# Never commit the real values — .env* is gitignored.

# BLOB_READ_WRITE_TOKEN — do NOT set this by hand. It's auto-injected by
# Vercel once a Blob store is connected to the project (Storage tab →
# Create Database → Blob → Connect Project). Without it, jobs fall back to
# in-process memory, which only works for a single local `next dev` run.

# Replicate — leave unset to use the free sharp-basic placeholder engine.
# Set it and the site automatically switches to real Real-ESRGAN restoration.
REPLICATE_API_TOKEN=

# Dodo Payments — test mode key first. Leave unset and checkout runs in
# demo mode (marks the job paid locally, no real charge, for pipeline testing).
DODO_API_KEY=
DODO_WEBHOOK_SECRET=

# Brand name / parent brand / price are NOT env vars — they're plain
# constants in src/lib/brand.ts (change that file, redeploy). Kept out of
# env because PRICE_USD is also read client-side and non-NEXT_PUBLIC_ env
# vars aren't available in the browser bundle.

# Free watermarked previews allowed per IP per day.
FREE_PREVIEWS_PER_DAY=5
